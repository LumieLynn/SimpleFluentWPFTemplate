<Application x:Class="SimpleTemplate.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:SimpleTemplate"
             xmlns:helpers="clr-namespace:SimpleTemplate.Helpers"
             xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
             xmlns:infra="clr-namespace:SimpleTemplate.Infrastructure"
             >
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemeResources/>
                <ui:XamlControlsResources/>
            </ResourceDictionary.MergedDictionaries>

            <helpers:ThemeToIndexConverter x:Key="ThemeToIndexConverter" />

            <infra:ViewLocator x:Key="GlobalViewLocator" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
